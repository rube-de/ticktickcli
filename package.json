{
  "name": "@rube-de/ticktickcli",
  "version": "0.1.2",
  "private": false,
  "description": "Agent-first TickTick CLI for tasks, projects, habits, focus, and calendar data",
  "type": "module",
  "license": "MIT",
  "author": "rube-de",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rube-de/ticktickcli.git"
  },
  "bugs": {
    "url": "https://github.com/rube-de/ticktickcli/issues"
  },
  "homepage": "https://github.com/rube-de/ticktickcli#readme",
  "keywords": [
    "ticktick",
    "todo",
    "tasks",
    "cli",
    "bun",
    "automation",
    "agents"
  ],
  "bin": {
    "tt": "src/index.ts"
  },
  "files": [
    "src",
    "skills/ticktick-cli",
    "docs/authentication.md",
    "docs/command-index.md",
    "docs/commands.md",
    "docs/configuration.md",
    "docs/releasing.md",
    "docs/man/tt.1",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "docs:generate": "bun run scripts/generate-command-docs.ts",
    "docs:check": "bun run scripts/generate-command-docs.ts --check",
    "test": "bun test",
    "test:package": "bun run scripts/package-smoke.ts",
    "check": "bun run typecheck && bun run lint && bun run docs:check && bun test && bun run test:package",
    "prepack": "bun run typecheck && bun run lint && bun run docs:check && bun test",
    "prepublishOnly": "bun run check"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "chalk": "^5.4.1",
    "chrono-node": "^2.8.0",
    "commander": "^13.1.0",
    "env-paths": "^3.0.0",
    "rrule": "^2.8.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "@inquirer/prompts": "^7.3.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.2.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
